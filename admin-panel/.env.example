# -------------------------------------------------------
# FMCG Sales & Delivery Management System
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   php artisan key:generate
# -------------------------------------------------------

# -------------------------------------------------------
# APPLICATION
# -------------------------------------------------------
APP_NAME="FMCG Sales System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -------------------------------------------------------
# LOGGING
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -------------------------------------------------------
# DATABASE
# Set DB_CONNECTION=mysql for XAMPP/production
# Set DB_CONNECTION=sqlite for quick local testing
# -------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fmcg_sales
DB_USERNAME=root
DB_PASSWORD=

# -------------------------------------------------------
# SESSION
# SESSION_LIFETIME is in minutes (480 = 8 hours)
# -------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -------------------------------------------------------
# QUEUE & CACHE
# -------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# -------------------------------------------------------
# REDIS (optional — only needed if using Redis cache/queue)
# -------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -------------------------------------------------------
# MAIL
# Use "log" driver locally (emails go to storage/logs)
# Use "smtp" in production
# -------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@fmcgsales.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# AWS S3 (optional — only if using S3 for file storage)
# -------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -------------------------------------------------------
# VITE
# -------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
